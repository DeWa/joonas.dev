---
layout: layouts/base.njk
eleventyNavigation:
  key: Blog
---
{% include "header.njk" %}
<section class="px-8 md:px-16 pt-4 md:pt-20 text-slate-200 font-header">
  <h1 class="text-slate-200 uppercase font-bold py-3 2xl:text-2xl">Latest posts</h1>
  <section class="flex flex-col md:flex-row flex-wrap justify-center items-center font-normal">
    {% set postlist = collections.posts | head(-4) %}
    {% set postslistCounter = collections.posts | length %}
    {% include "postslist.njk" %}
  </section>
  {% set postsByYear = collections.postsByYearAndMonth %}
  {% for year, months in postsByYear %}
    <details>
      <summary class="text-xl 2xl:text-2xl">{{year}}</summary>
      {% for month, posts in months %}
        <details class="ml-4">
          <summary class="text-xl">{{month}}</summary>
          <div class="flex">
            {% for post in posts %}
              <a href="{{ post.url | url }}">
                <article class="rounded bg-cover w-72 h-60 grid content-end m-5" style="background-image: url('{% imageBg post.data.coverPath, 'png', 200 %}')">
                  <div class="backdrop-blur-sm bg-white/30 text-slate-200 p-2 rounded-b font-normal">
                    <p class="text-xs font-header">{{post.data.date | readableDate}}</p>
                    <h1>{{post.data.title}}</h1>
                    {% for tag in post.data.tags %}
                      <object class="inline">
                        <a href="{{ '/tags/' | url }}{{ tag }}">
                          <span class="text-xs font-header inline-block py-1 px-2.5 leading-none text-center whitespace-nowrap align-baseline text-white rounded-full bg-gradient-to-r from-blue-700 to-fuchsia-800">{{tag}}</span>
                        </a>
                      </object>
                    {% endfor %}
                  </div>
                </article>
              </a>
            {% endfor %}
          </div>
        </details>
      {% endfor %}
    </details>
  {% endfor %}
</section>
{% set postslistCounter = collections.posts | length %}