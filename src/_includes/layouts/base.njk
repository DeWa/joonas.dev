<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title or metadata.title }}</title>
    <meta name="description" content="{{ description or metadata.description }}">
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,300;0,400;0,900;1,400;1,700&display=swap">
    <link href="https://fonts.googleapis.com/css2?family=Permanent+Marker&display=swap" rel="stylesheet">
    <link rel="alternate" href="{{ metadata.feed.path | url }}" type="application/atom+xml" title="{{ metadata.title }}">
    <link rel="alternate" href="{{ metadata.jsonfeed.path | url }}" type="application/json" title="{{ metadata.title }}">
    <link rel="stylesheet" href="{{ '/assets/css/tailwind.css' | url }}">
    <style>
      {{css | safe}}
    </style>
  </head>
  <body class="bg-gradient-to-r from-darkestBlue to-darkestPink">
    <main class="px-8 md:px-16">
      {{ content | safe }}
    </main>
    <footer></footer>
    <!-- Current page: {{ page.url | url }} -->
  </body>
</html>
