{
  "name": "joonas.dev",
  "version": "1.0.0",
  "description": "Personal site",
  "main": "_site/index.html",
  "scripts": {
    "build": "run-s build:*",
    "build:11ty": "eleventy",
    "build:css": "tailwindcss -i src/assets/css/tailwind.css -o dist/assets/css/tailwind.css --postcss",
    "watch": "eleventy --watch",
    "debug": "DEBUG=* eleventy",
    "start": "npm-run-all -p dev:*",
    "dev:11ty": "eleventy --serve",
    "dev:css": "tailwindcss -i src/assets/css/tailwind.css -o dist/assets/css/tailwind.css --watch --postcss"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DeWa/joonas.dev"
  },
  "author": "Joonas Reinikka <joonas.reinikka@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/DeWa/joonas.dev/issues"
  },
  "homepage": "https://github.com/DeWa/joonas.dev#readme",
  "devDependencies": {
    "@11ty/eleventy": "^1.0.0",
    "@11ty/eleventy-img": "^2.0.0",
    "@11ty/eleventy-navigation": "^0.3.2",
    "@11ty/eleventy-plugin-rss": "^1.1.2",
    "@11ty/eleventy-plugin-syntaxhighlight": "^4.0.0",
    "autoprefixer": "^10.4.12",
    "markdown-it-anchor": "^8.4.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.16",
    "postcss-cli": "^9.1.0",
    "tailwindcss": "^3.1.8"
  }
}
